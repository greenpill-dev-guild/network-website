---
// Graph explorer component - loads force-graph from npm
---

<div class="explorer-shell">
  <header class="explorer-topbar">
    <a class="explorer-brand" href="/">
      <img src="/images/greenpill-logo.svg" width="40" height="40" alt="Greenpill logo" />
      <div>
        <span class="eyebrow">Greenpill</span>
        <strong>Knowledge Explorer</strong>
      </div>
    </a>
    <nav class="explorer-nav">
      <a href="/#network">Network</a>
      <a href="/#podcast">Podcast</a>
      <a href="/#participate">Participate</a>
      <a href="/#explore">Home</a>
    </nav>
  </header>

  <main class="explorer-main">
    <section class="control-panel">
      <div class="control-group">
        <span class="control-label">Dataset</span>
        <div class="pill-row" id="dataset-pills"></div>
      </div>

      <form class="search-group" id="search-form">
        <label class="control-label" for="node-search">Find a node</label>
        <div class="search-row">
          <input id="node-search" list="node-search-list" type="search"
            placeholder="Gitcoin, Greenpill Garden, Kevin Owocki..." />
          <datalist id="node-search-list"></datalist>
          <button type="submit" class="primary">Focus</button>
        </div>
      </form>
    </section>

    <section class="explorer-grid">
      <article class="stage-card">
        <div class="stage-header">
          <div>
            <p class="eyebrow">Interactive map</p>
            <h2 id="stage-title">Bridge View</h2>
          </div>
        </div>

        <div class="legend-bar">
          <span class="legend-item"><i class="legend-dot layer-network"></i>Network</span>
          <span class="legend-item"><i class="legend-dot layer-podcast"></i>Podcast</span>
          <span class="legend-item"><i class="legend-dot layer-bridge"></i>Bridge</span>
          <span class="legend-item"><i class="legend-dot edge-capital"></i>Capital flow</span>
        </div>

        <div class="graph-wrap" id="graph-wrap">
          <div class="graph-surface" id="graph-2d"></div>
          <div class="graph-empty hidden" id="graph-empty">No nodes match the current filters.</div>
        </div>
      </article>

      <aside class="inspector-card">
        <div class="inspector-header">
          <div>
            <p class="eyebrow">Inspector</p>
            <h2>Node Details</h2>
          </div>
          <button class="secondary inspector-clear" id="clear-selection" type="button">Clear</button>
        </div>
        <div class="inspector-body" id="inspector-body"></div>
      </aside>
    </section>
  </main>
</div>

