---
interface Props {
  title: string;
  image: string;
  imageAlt: string;
  imageWidth?: number;
  imageHeight?: number;
  ebookLink: string;
  formats?: Array<{ label: string; link: string }>;
  translationsId?: string;
  imageStyle?: string;
}

const { title, image, imageAlt, imageWidth = 200, imageHeight = 300, ebookLink, formats = [], translationsId, imageStyle } = Astro.props;
const hasDropdown = formats.length > 0;
const dropdownHeight = formats.length * 40;
---

<div class="flex flex-col items-center">
  <img src={image} width={imageWidth} height={imageHeight}
    class="mb-4 w-auto max-h-[230px] 2xl:w-[200px] 2xl:h-[300px] 2xl:max-h-none"
    alt={imageAlt} style={imageStyle} />
  <div>
    <div class="flex gap-4 justify-center items-start xl:flex-row flex-col mb-3">
      <div class="border border-green rounded-[20px] hover:border-[var(--mid-green)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-300 dropdown-btn divide-y divide-green flex flex-col">
        <button class="secondary !border-none flex gap-4 justify-between items-center">
          <span class="dropdown-btn-selected" data-link={ebookLink}>
            Ebook
          </span>
          {hasDropdown && (
            <span>
              <svg width="14" height="9" viewBox="0 0 14 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L5.4 6.86667C6.2 7.93333 7.8 7.93333 8.6 6.86667L10 5L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          )}
        </button>
        {hasDropdown && (
          <div class="divide-y border border-[var(--mid-green)] rounded-[20px] backdrop-blur-md divide-green fixed top-full left-0 right-0 bg-black bg-opacity-50 flex-col dropdown-btn-content hidden h-0 opacity-0 transition-all duration-300" data-height={dropdownHeight}>
            {formats.map((fmt) => (
              <a class="link !font-bold dropdown-btn-option" data-link={fmt.link}>
                {fmt.label}
              </a>
            ))}
          </div>
        )}
      </div>
      <a class="dropdown-btn-shop" href={ebookLink} target="_blank">
        <button class="primary">Get it (free)</button>
      </a>
    </div>
    {translationsId && (
      <div class="flex flex-wrap justify-center xl:flex-row flex-col items-center">
        <button class="link sm:text-base text-sm p-0" id={`${translationsId}-modal-btn`}>
          Translations
        </button>
      </div>
    )}
  </div>
</div>
